generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  password      String?
  auraPoints    Int           @default(0)
  auraLevel     Int           @default(1)
  missionsCompleted Int       @default(0)
  foxBadges     Int           @default(0)
  comboStreak   Int           @default(0)
  maxCombo      Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  sessions      Session[]
  userMissions  UserMission[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Mission {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  order           Int           @unique
  title           String
  description     String
  briefing        String        @default("")
  difficulty      String        @default("EASY")
  language        String        @default("C")
  type            String        @default("standard")
  goal            String?
  startingCode    String?
  auraReward      Int           @default(100)
  teachingContent String?       // JSON string of slides
  mcqContent      String?       // JSON string of MCQs
  validationRules String?       // JSON: { requiredKeywords, forbiddenPatterns, minLength, requiredOutput }
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userMissions    UserMission[]
}

model UserMission {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  userId             String    @db.ObjectId
  missionId          String    @db.ObjectId
  status             String    @default("LOCKED")
  phase              String    @default("TEACHING") // TEACHING, MCQ, CODING
  hintsUsed          Int       @default(0)
  attemptCount       Int       @default(0)
  innovationUnlocked Boolean   @default(false)
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([userId])
  @@index([missionId])
}

model DailyQuestion {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  question      String
  options       String   // JSON array of strings
  correctAnswer String   // The correct option
  explanation   String   // Explains why it's correct
  createdAt     DateTime @default(now())
}
